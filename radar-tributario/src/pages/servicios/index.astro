---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import { getAllServices } from '../../lib/sanity/queries';
import { PILLARS } from '../../lib/pillars';
import { PILLAR_ICON_PATHS } from '../../lib/pillar-icons';
import { getServiceIconPaths } from '../../lib/service-icons';
import type { Service } from '../../lib/sanity/types';

const services = await getAllServices();
const columns = PILLARS.map((p, i) => ({
  ...p,
  services: services.filter((s: Service) => s.pillar === p.key),
  alt: i % 2 === 1,
}));
---

<BaseLayout
  title="Servicios | Radar Tributario"
  description="Servicios tributarios, contables y de RRHH para independientes, pymes y empresas en Chile, organizados en 3 áreas."
>
  <section class="bg-primary">
    <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8 lg:py-20">
      <h1 class="font-heading text-3xl font-medium text-background sm:text-4xl">Servicios</h1>
      <p class="mt-3 max-w-xl font-body text-[15px] text-background/70">
        {services.length} servicios organizados en 3 áreas. Elige la que te haga sentido y revisa el detalle,
        o cuéntanos tu caso directamente si no estás seguro.
      </p>
    </div>
  </section>

  {
    columns.map((col) => (
      <section class:list={['border-t border-primary/10', col.alt ? 'bg-background' : 'bg-surface']}>
        <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8 lg:py-20">
          <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
            <div class="flex items-start gap-4">
              <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-primary/[0.06] text-primary">
                <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={PILLAR_ICON_PATHS[col.key]} />
              </span>
              <div>
                <p class="font-body text-[11px] font-semibold uppercase tracking-[0.12em] text-secondary">{col.label}</p>
                <h2 class="mt-1 font-heading text-2xl font-medium text-primary sm:text-3xl">{col.blurb}</h2>
              </div>
            </div>
            <a
              href={`/servicios/${col.key}/`}
              class="group inline-flex shrink-0 items-center gap-1.5 rounded-md bg-primary px-5 py-2.5 font-body text-[13px] font-medium text-background shadow-sm transition-colors hover:bg-accent hover:text-on-accent"
            >
              Ver {col.label.toLowerCase()} completo
              <svg class="h-3.5 w-3.5 transition-transform duration-300 group-hover:rotate-45" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4M9.5 2.5V8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
          </div>

          <div class="mt-10 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {col.services.map((s: Service) => (
              <a
                href={`/servicios/${s.pillar}/${s.slug.current}/`}
                class="group relative flex flex-col rounded-xl border border-primary/10 bg-surface p-6 shadow-sm transition-all hover:-translate-y-0.5 hover:border-primary/20 hover:shadow-md"
              >
                <span class="mb-3.5 flex h-9 w-9 items-center justify-center rounded-full bg-primary/[0.06] text-primary transition-colors group-hover:bg-accent/15 group-hover:text-secondary">
                  <svg class="h-[17px] w-[17px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={getServiceIconPaths(s.slug.current, s.pillar)} />
                </span>
                <h3 class="relative inline-block font-heading text-lg leading-snug text-primary transition-colors group-hover:text-secondary">
                  <span class="relative">
                    {s.title}
                    <span class="pointer-events-none absolute inset-x-0 -bottom-0.5 h-px bg-primary/20" aria-hidden="true" />
                    <span
                      class="pointer-events-none absolute inset-x-0 -bottom-0.5 h-px origin-left scale-x-0 bg-accent transition-transform duration-300 ease-out group-hover:scale-x-100"
                      aria-hidden="true"
                    />
                  </span>
                </h3>
                {s.shortDescription && <p class="mt-2.5 line-clamp-3 font-body text-[13.5px] leading-relaxed text-text/70">{s.shortDescription}</p>}
                <svg
                  class="mt-auto h-3.5 w-3.5 self-end pt-4 text-primary/30 transition-all duration-300 group-hover:rotate-45 group-hover:text-secondary"
                  viewBox="0 0 12 12"
                  fill="none"
                  aria-hidden="true"
                >
                  <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4M9.5 2.5V8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </a>
            ))}
          </div>
        </div>
      </section>
    ))
  }
</BaseLayout>
