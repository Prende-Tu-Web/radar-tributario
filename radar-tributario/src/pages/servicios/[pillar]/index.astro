---
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import { getServicesByPillar } from '../../../lib/sanity/queries';
import { PILLARS } from '../../../lib/pillars';
import { PILLAR_ICON_PATHS } from '../../../lib/pillar-icons';
import { getServiceIconPaths } from '../../../lib/service-icons';
import { breadcrumbJsonLd } from '../../../lib/seo';
import type { Service } from '../../../lib/sanity/types';

export async function getStaticPaths() {
  return PILLARS.map((p) => ({
    params: { pillar: p.key },
    props: { pillar: p.key, label: p.label, blurb: p.blurb },
  }));
}

interface Props {
  pillar: 'tributario' | 'contable' | 'rrhh';
  label: string;
  blurb: string;
}

const { pillar, label, blurb } = Astro.props;
const services = await getServicesByPillar(pillar);

const breadcrumb = breadcrumbJsonLd([
  { name: 'Servicios', url: new URL('/servicios/', Astro.site).toString() },
  { name: label, url: new URL(`/servicios/${pillar}/`, Astro.site).toString() },
]);
---

<BaseLayout
  title={`Servicios de ${label} | Radar Tributario`}
  description={`${blurb}. Servicios de ${label.toLowerCase()} para independientes, pymes y empresas en Chile.`}
>
  <script is:inline type="application/ld+json" slot="jsonld" set:html={JSON.stringify(breadcrumb)} />
  <nav aria-label="Breadcrumb" class="border-b border-primary/10 bg-background">
    <div class="mx-auto max-w-7xl px-4 py-3 sm:px-6 lg:px-8">
      <ol class="flex items-center gap-1.5 font-body text-[12.5px] text-muted">
        <li><a href="/servicios/" class="hover:text-secondary">Servicios</a></li>
        <li aria-hidden="true">/</li>
        <li aria-current="page" class="text-primary">{label}</li>
      </ol>
    </div>
  </nav>

  <section class="bg-primary">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
      <div class="flex flex-col gap-10 lg:flex-row lg:items-end lg:justify-between">
        <div class="flex items-start gap-5">
          <span class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-white/10 text-accent">
            <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={PILLAR_ICON_PATHS[pillar]} />
          </span>
          <div>
            <p class="font-body text-[11px] font-semibold uppercase tracking-[0.14em] text-accent">{label}</p>
            <h1 class="mt-2 max-w-xl font-heading text-[2.25rem] font-medium leading-[1.1] text-background sm:text-[2.75rem]">{blurb}</h1>
          </div>
        </div>
        <div class="shrink-0">
          <p class="font-heading text-6xl leading-none text-accent sm:text-7xl">{services.length}</p>
          <p class="mt-3 font-body text-[11px] font-semibold uppercase tracking-[0.14em] text-background/60">Servicios disponibles</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-surface">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          services.map((s: Service) => (
            <a
              href={`/servicios/${s.pillar}/${s.slug.current}/`}
              class="group relative flex flex-col rounded-xl border border-primary/10 bg-surface p-6 shadow-sm transition-all hover:-translate-y-0.5 hover:border-primary/20 hover:shadow-md"
            >
              <span class="mb-3.5 flex h-9 w-9 items-center justify-center rounded-full bg-primary/[0.06] text-primary transition-colors group-hover:bg-accent/15 group-hover:text-secondary">
                <svg class="h-[17px] w-[17px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={getServiceIconPaths(s.slug.current, s.pillar)} />
              </span>
              <h2 class="relative inline-block font-heading text-lg leading-snug text-primary transition-colors group-hover:text-secondary">
                <span class="relative">
                  {s.title}
                  <span class="pointer-events-none absolute inset-x-0 -bottom-0.5 h-px bg-primary/20" aria-hidden="true" />
                  <span
                    class="pointer-events-none absolute inset-x-0 -bottom-0.5 h-px origin-left scale-x-0 bg-accent transition-transform duration-300 ease-out group-hover:scale-x-100"
                    aria-hidden="true"
                  />
                </span>
              </h2>
              {s.shortDescription && <p class="mt-2.5 line-clamp-3 font-body text-[13.5px] leading-relaxed text-text/70">{s.shortDescription}</p>}
              <svg
                class="mt-auto h-3.5 w-3.5 self-end pt-4 text-primary/30 transition-all duration-300 group-hover:rotate-45 group-hover:text-secondary"
                viewBox="0 0 12 12"
                fill="none"
                aria-hidden="true"
              >
                <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4M9.5 2.5V8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
