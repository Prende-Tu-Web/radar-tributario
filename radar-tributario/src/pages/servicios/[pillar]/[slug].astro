---
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import PillarNav from '../../../components/services/PillarNav.astro';
import ServiceHero from '../../../components/services/ServiceHero.astro';
import ServiceVariantsTable from '../../../components/services/ServiceVariantsTable.astro';
import ServiceBenefits from '../../../components/services/ServiceBenefits.astro';
import ServiceFAQ from '../../../components/services/ServiceFAQ.astro';
import LeadForm from '../../../components/islands/LeadForm';
import { getAllServices, getSiteSettings } from '../../../lib/sanity/queries';
import { getPillarLabel } from '../../../lib/pillars';
import { serviceJsonLd, faqJsonLd, breadcrumbJsonLd } from '../../../lib/seo';
import type { Service } from '../../../lib/sanity/types';

export async function getStaticPaths() {
  const services = await getAllServices();
  return services.map((service: Service) => ({
    params: { pillar: service.pillar, slug: service.slug.current },
    props: { service, allServices: services },
  }));
}

interface Props {
  service: Service;
  allServices: Service[];
}

const { service, allServices } = Astro.props;
const pillarLabel = getPillarLabel(service.pillar);
const siteSettings = await getSiteSettings();
const showCalendly = Boolean(service.showScheduler && siteSettings?.calendlyUrl);
const serviceOptions = allServices.map((s) => ({ slug: s.slug.current, title: s.title, pillar: s.pillar }));

const breadcrumb = breadcrumbJsonLd([
  { name: 'Servicios', url: new URL('/servicios/', Astro.site).toString() },
  { name: pillarLabel, url: new URL(`/servicios/${service.pillar}/`, Astro.site).toString() },
  { name: service.title, url: new URL(`/servicios/${service.pillar}/${service.slug.current}/`, Astro.site).toString() },
]);
---

<BaseLayout
  title={service.seo?.metaTitle || `${service.title} | Radar Tributario`}
  description={service.seo?.metaDescription || service.shortDescription || service.heroDescription || service.title}
>
  <script is:inline type="application/ld+json" slot="jsonld" set:html={JSON.stringify(serviceJsonLd(service))} />
  <script is:inline type="application/ld+json" slot="jsonld" set:html={JSON.stringify(breadcrumb)} />
  {service.faq && service.faq.length > 0 && (
    <script is:inline type="application/ld+json" slot="jsonld" set:html={JSON.stringify(faqJsonLd(service.faq))} />
  )}
  <PillarNav pillar={service.pillar} pillarLabel={pillarLabel} current={service.title} />
  <ServiceHero service={service} pillarLabel={pillarLabel} hasFaq={Boolean(service.faq && service.faq.length > 0)} />

  {service.variants && service.variants.length > 0 && <ServiceVariantsTable variants={service.variants} />}
  {service.benefits && service.benefits.length > 0 && <ServiceBenefits benefits={service.benefits} />}
  {service.faq && service.faq.length > 0 && <ServiceFAQ faq={service.faq} />}

  <section id="contacto-servicio" class="relative scroll-mt-16 overflow-hidden border-t border-primary/10 bg-primary lg:scroll-mt-20">
    <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
      <div
        class="absolute inset-0 bg-cover bg-center bg-fixed opacity-45"
        style="background-image: url('https://images.unsplash.com/photo-1767988048897-2dca103ff620?fm=jpg&q=60&w=1600&auto=format&fit=crop')"
      >
      </div>
      <div class="absolute inset-0 bg-gradient-to-br from-primary/95 via-primary/80 to-primary/60"></div>
    </div>

    <div class="relative mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8 lg:py-20">
      <div class="grid grid-cols-1 gap-10 lg:grid-cols-2 lg:gap-16">
        <div class="lg:pr-8 lg:pt-6">
          <h2 class="font-heading text-2xl font-medium text-background sm:text-3xl">
            Cotiza {service.title.toLowerCase()}.
          </h2>
          <p class="mt-3 max-w-md font-body text-[15px] leading-relaxed text-background/70">
            Completa el formulario y te respondemos directo a tu correo o teléfono.
            {showCalendly && ' También puedes agendar una reunión directamente si prefieres conversarlo primero.'}
          </p>
          {
            showCalendly && (
              <a
                href={siteSettings!.calendlyUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-5 inline-flex items-center gap-1.5 font-body text-[13px] font-medium text-accent underline decoration-accent/40 underline-offset-4 hover:decoration-accent"
              >
                Agendar una reunión
              </a>
            )
          }
          {
            service.benefits && service.benefits.length > 0 && (
              <ul class="mt-8 space-y-3 border-t border-white/10 pt-6">
                {service.benefits.map((b) => (
                  <li class="flex items-center gap-3 font-body text-[13.5px] text-background/85">
                    <svg class="h-4 w-4 shrink-0 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M20 6L9 17l-5-5" />
                    </svg>
                    {b.title}
                  </li>
                ))}
              </ul>
            )
          }
        </div>
        <div class="rounded-xl border border-white/40 bg-white/70 p-6 shadow-[0_20px_50px_-20px_rgba(0,0,0,0.5)] backdrop-blur-xl sm:p-8">
          <LeadForm client:load service={service.slug.current} pillar={service.pillar} services={serviceOptions} />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
