---
import BaseLayout from '../components/layout/BaseLayout.astro';
import LeadForm from '../components/islands/LeadForm';
import { getSiteSettings } from '../lib/sanity/queries';

const siteSettings = await getSiteSettings();
const hasWhatsapp = Boolean(siteSettings?.whatsappNumber);
const hasCalendly = Boolean(siteSettings?.calendlyUrl);

const WHATSAPP_ICON =
  '<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />';
const CALENDAR_ICON = '<rect x="3" y="4" width="18" height="17" rx="2" /><path d="M16 2v4M8 2v4M3 9h18" />';
---

<BaseLayout
  title="Contacto | Radar Tributario"
  description="Escríbenos y te respondemos directo a tu correo o teléfono. Sin IVR ni derivaciones."
>
  <section class="relative overflow-hidden bg-primary">
    <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
      <div
        class="absolute inset-0 bg-cover bg-center bg-fixed opacity-45"
        style="background-image: url('https://images.unsplash.com/photo-1767988048897-2dca103ff620?fm=jpg&q=60&w=1600&auto=format&fit=crop')"
      >
      </div>
      <div class="absolute inset-0 bg-gradient-to-br from-primary/95 via-primary/80 to-primary/60"></div>
      <span class="absolute -bottom-16 -left-10 select-none font-heading text-[15rem] italic leading-none text-white/[0.045] sm:text-[19rem]">§</span>
    </div>

    <div class="relative mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-[1fr_1.3fr] lg:gap-16">
        <div class="lg:pr-8 lg:pt-6">
          <p class="font-body text-[11px] font-semibold uppercase tracking-[0.14em] text-accent">Contacto</p>
          <h1 class="mt-3 font-heading text-[2.5rem] font-medium leading-[1.1] text-background sm:text-[3rem]">
            Cuéntanos qué necesitas.
          </h1>
          <p class="mt-5 max-w-md font-body text-[15px] leading-relaxed text-background/70">
            Completa el formulario y te respondemos directo a tu correo o teléfono en las próximas horas hábiles.
          </p>

          {
            (hasWhatsapp || hasCalendly) && (
              <div class="mt-8 flex flex-col gap-4 border-t border-white/10 pt-7">
                {hasWhatsapp && (
                  <a href={`https://wa.me/${siteSettings!.whatsappNumber}`} target="_blank" rel="noopener noreferrer" class="group flex items-center gap-3 font-body text-[14px] font-medium text-background/85 transition-colors hover:text-background">
                    <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-white/10 text-accent transition-colors group-hover:bg-accent group-hover:text-on-accent">
                      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={WHATSAPP_ICON} />
                    </span>
                    <span class="relative">
                      Escríbenos por WhatsApp
                      <span class="pointer-events-none absolute inset-x-0 -bottom-0.5 h-px bg-background/30" aria-hidden="true" />
                      <span class="pointer-events-none absolute inset-x-0 -bottom-0.5 h-px origin-left scale-x-0 bg-accent transition-transform duration-300 ease-out group-hover:scale-x-100" aria-hidden="true" />
                    </span>
                  </a>
                )}
                {hasCalendly && (
                  <a href={siteSettings!.calendlyUrl} target="_blank" rel="noopener noreferrer" class="group flex items-center gap-3 font-body text-[14px] font-medium text-background/85 transition-colors hover:text-background">
                    <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-white/10 text-accent transition-colors group-hover:bg-accent group-hover:text-on-accent">
                      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={CALENDAR_ICON} />
                    </span>
                    <span class="relative">
                      Agenda una reunión directamente
                      <span class="pointer-events-none absolute inset-x-0 -bottom-0.5 h-px bg-background/30" aria-hidden="true" />
                      <span class="pointer-events-none absolute inset-x-0 -bottom-0.5 h-px origin-left scale-x-0 bg-accent transition-transform duration-300 ease-out group-hover:scale-x-100" aria-hidden="true" />
                    </span>
                  </a>
                )}
              </div>
            )
          }

          <div class="mt-10 flex gap-10 border-t border-white/10 pt-7">
            <div>
              <p class="font-heading text-3xl leading-none text-accent">+8</p>
              <p class="mt-2 font-body text-[11px] font-semibold uppercase tracking-[0.12em] text-background/60">Años de experiencia</p>
            </div>
            <div>
              <p class="font-heading text-3xl leading-none text-accent">+50</p>
              <p class="mt-2 font-body text-[11px] font-semibold uppercase tracking-[0.12em] text-background/60">Clientes gestionados</p>
            </div>
          </div>
        </div>

        <div class="rounded-xl border border-white/40 bg-white/70 p-6 shadow-[0_20px_50px_-20px_rgba(0,0,0,0.5)] backdrop-blur-xl sm:p-8">
          <LeadForm client:load service="general" />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
