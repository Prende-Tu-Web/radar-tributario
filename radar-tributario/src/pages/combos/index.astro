---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import { getCombos } from '../../lib/sanity/queries';
import { COMBO_CTA_LABEL, COMBO_CTA_ICON } from '../../lib/combo-icons';
import type { Combo } from '../../lib/sanity/types';

const combos = await getCombos();
---

<BaseLayout
  title="Combos de entrada | Radar Tributario"
  description="Ofertas de entrada para empezar rápido: diagnóstico tributario, cotización de RRHH y reserva anticipada de Operación Renta."
>
  <section class="bg-primary">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
      <div class="flex flex-col gap-10 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="font-body text-[11px] font-semibold uppercase tracking-[0.14em] text-accent">Combos de entrada</p>
          <h1 class="mt-3 max-w-xl font-heading text-[2.25rem] font-medium leading-[1.1] text-background sm:text-[2.75rem]">
            Formas rápidas de partir cuando no sabes bien por dónde empezar.
          </h1>
          <p class="mt-4 max-w-lg font-body text-[15px] leading-relaxed text-background/70">
            Resuelven lo urgente primero, sin que tengas que comprometerte al catálogo completo todavía.
          </p>
        </div>
        <div class="shrink-0">
          <p class="font-heading text-6xl leading-none text-accent sm:text-7xl">{combos.length}</p>
          <p class="mt-3 font-body text-[11px] font-semibold uppercase tracking-[0.14em] text-background/60">Combos activos</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-surface">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          combos.map((c: Combo) => (
            <a
              href={`/combos/${c.slug.current}/`}
              class="group relative flex flex-col rounded-xl border border-primary/10 bg-surface p-7 shadow-sm transition-all hover:-translate-y-0.5 hover:border-primary/20 hover:shadow-md"
            >
              <span class="flex h-10 w-10 items-center justify-center rounded-full bg-primary/[0.06] text-primary transition-colors group-hover:bg-accent/15 group-hover:text-secondary">
                <svg class="h-[19px] w-[19px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={COMBO_CTA_ICON[c.ctaType]} />
              </span>
              <p class="mt-4 font-body text-[11px] font-semibold uppercase tracking-[0.1em] text-secondary">{COMBO_CTA_LABEL[c.ctaType]}</p>
              <h2 class="relative mt-1.5 inline-block font-heading text-xl leading-snug text-primary transition-colors group-hover:text-secondary">
                <span class="relative">
                  {c.title}
                  <span class="pointer-events-none absolute inset-x-0 -bottom-0.5 h-px bg-primary/20" aria-hidden="true" />
                  <span
                    class="pointer-events-none absolute inset-x-0 -bottom-0.5 h-px origin-left scale-x-0 bg-accent transition-transform duration-300 ease-out group-hover:scale-x-100"
                    aria-hidden="true"
                  />
                </span>
              </h2>
              {c.description && <p class="mt-2.5 font-body text-[13.5px] leading-relaxed text-text/70">{c.description}</p>}
              <svg
                class="mt-auto h-3.5 w-3.5 self-end pt-4 text-primary/30 transition-all duration-300 group-hover:rotate-45 group-hover:text-secondary"
                viewBox="0 0 12 12"
                fill="none"
                aria-hidden="true"
              >
                <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4M9.5 2.5V8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
