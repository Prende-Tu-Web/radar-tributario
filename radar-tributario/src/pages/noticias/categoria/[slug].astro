---
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import PostCard from '../../../components/blog/PostCard.astro';
import { getCategories, getPostsByCategory } from '../../../lib/sanity/queries';
import { CATEGORIES_FALLBACK } from '../../../lib/categories-fallback';
import { categoryDotClass } from '../../../lib/category-colors';
import { breadcrumbJsonLd } from '../../../lib/seo';
import type { Category } from '../../../lib/sanity/types';

export async function getStaticPaths() {
  const fromSanity = await getCategories();
  const categories = fromSanity.length > 0 ? fromSanity : CATEGORIES_FALLBACK;
  return categories.map((cat: Category) => ({
    params: { slug: cat.slug.current },
    props: { category: cat },
  }));
}

interface Props {
  category: Category;
}

const { category } = Astro.props;
const posts = await getPostsByCategory(category.slug.current);

const breadcrumb = breadcrumbJsonLd([
  { name: 'Noticias', url: new URL('/noticias/', Astro.site).toString() },
  { name: category.title, url: new URL(`/noticias/categoria/${category.slug.current}/`, Astro.site).toString() },
]);
---

<BaseLayout
  title={`${category.title} | Noticias | Radar Tributario`}
  description={category.description || `Artículos sobre ${category.title} en Radar Tributario.`}
>
  <script is:inline type="application/ld+json" slot="jsonld" set:html={JSON.stringify(breadcrumb)} />
  <nav aria-label="Breadcrumb" class="border-b border-primary/10 bg-background">
    <div class="mx-auto max-w-7xl px-4 py-3 sm:px-6 lg:px-8">
      <ol class="flex items-center gap-1.5 font-body text-[12.5px] text-muted">
        <li><a href="/noticias/" class="hover:text-secondary">Noticias</a></li>
        <li aria-hidden="true">/</li>
        <li aria-current="page" class="text-primary">{category.title}</li>
      </ol>
    </div>
  </nav>

  <section class="bg-primary">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
      <div class="flex flex-col gap-10 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="flex items-center gap-2 font-body text-[11px] font-semibold uppercase tracking-[0.14em] text-accent">
            <span class={`h-1.5 w-1.5 shrink-0 rounded-full ${categoryDotClass(category.color)}`} aria-hidden="true" />
            Categoría
          </p>
          <h1 class="mt-3 max-w-xl font-heading text-[2.25rem] font-medium leading-[1.1] text-background sm:text-[2.75rem]">{category.title}</h1>
          {category.description && <p class="mt-4 max-w-lg font-body text-[15px] leading-relaxed text-background/70">{category.description}</p>}
        </div>
        <div class="shrink-0">
          <p class="font-heading text-6xl leading-none text-accent sm:text-7xl">{posts.length}</p>
          <p class="mt-3 font-body text-[11px] font-semibold uppercase tracking-[0.14em] text-background/60">{posts.length === 1 ? 'Artículo' : 'Artículos'}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-surface">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
      {
        posts.length === 0 ? (
          <div class="max-w-xl border-l border-dashed border-muted/40 pl-6 py-2">
            <p class="font-heading text-lg italic text-primary">Todavía no hay artículos publicados en esta categoría.</p>
            <p class="mt-2 font-body text-[13.5px] text-muted">Vuelve pronto — estamos preparando los primeros análisis.</p>
          </div>
        ) : (
          <div class="grid grid-cols-1 items-stretch gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {posts.map((post) => (
              <PostCard post={post} />
            ))}
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>
