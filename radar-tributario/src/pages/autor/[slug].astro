---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import PostCard from '../../components/blog/PostCard.astro';
import { getAuthors, getPostsByAuthor } from '../../lib/sanity/queries';
import { AUTHORS_FALLBACK } from '../../lib/authors-fallback';
import { AUTHOR_LINKEDIN } from '../../lib/author-links';
import { getAuthorPhotoUrl } from '../../lib/author-photos';
import { SOCIAL_ICONS } from '../../lib/social-icons';
import { urlFor } from '../../lib/sanity/image';
import type { Author } from '../../lib/sanity/types';

export async function getStaticPaths() {
  const fromSanity = await getAuthors();
  const authors = fromSanity.length > 0 ? fromSanity : AUTHORS_FALLBACK;
  return authors.map((author: Author) => ({
    params: { slug: author.slug.current },
    props: { author },
  }));
}

interface Props {
  author: Author;
}

const { author } = Astro.props;
const posts = await getPostsByAuthor(author.slug.current);
const bioParagraphs = (author.bio ?? '').split('\n').filter(Boolean);
const linkedin = AUTHOR_LINKEDIN[author.slug.current];
const photoUrl = author.photo ? urlFor(author.photo).width(192).height(192).fit('crop').url() : getAuthorPhotoUrl(author.slug.current);
---

<BaseLayout
  title={`${author.name} | Radar Tributario`}
  description={author.shortBio || `Perfil de ${author.name} en Radar Tributario.`}
>
  <section class="bg-surface">
    <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
      <div class="flex items-center gap-6">
        <div class="h-24 w-24 shrink-0 overflow-hidden rounded-full">
          {photoUrl ? (
            <img src={photoUrl} alt={author.name} class="h-full w-full object-cover" />
          ) : (
            <div class="flex h-full w-full items-center justify-center bg-primary/[0.06] font-heading text-3xl font-medium text-primary">{author.name.charAt(0)}</div>
          )}
        </div>
        <div>
          <h1 class="font-heading text-3xl font-medium leading-tight text-primary sm:text-4xl">{author.name}</h1>
          {author.credentials && <p class="mt-1.5 font-body text-[14px] text-secondary">{author.credentials}</p>}
          {
            linkedin && (
              <a
                href={linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-3 inline-flex items-center gap-1.5 rounded-full border border-primary/15 px-3 py-1.5 font-body text-[12.5px] font-medium text-primary transition-all hover:-translate-y-0.5 hover:border-accent hover:bg-accent hover:text-on-accent"
              >
                <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={SOCIAL_ICONS.linkedin.path} />
                LinkedIn
              </a>
            )
          }
        </div>
      </div>

      {bioParagraphs.length > 0 && (
        <div class="mt-10 space-y-4 border-t border-primary/10 pt-8">
          {bioParagraphs.map((p) => (
            <p class="font-body text-[16px] leading-relaxed text-text/85">{p}</p>
          ))}
        </div>
      )}

      {posts.length > 0 && (
        <div class="mt-14 border-t border-primary/10 pt-8">
          <h2 class="font-heading text-xl font-medium text-primary">Artículos de {author.name}</h2>
          <div class="mt-6 grid grid-cols-1 gap-6 sm:grid-cols-2">
            {posts.map((post) => (
              <PostCard post={post} />
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
