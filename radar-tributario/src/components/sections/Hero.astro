---
import HeroConstellation from './HeroConstellation.astro';
---

<section class="hero-dark relative overflow-hidden">
  <div class="relative mx-auto grid max-w-7xl grid-cols-1 items-center gap-12 px-4 pb-16 pt-14 sm:px-6 sm:pb-20 sm:pt-20 lg:grid-cols-[minmax(0,1fr)_24rem] lg:px-8 lg:pb-28 lg:pt-24 xl:grid-cols-[minmax(0,1fr)_28rem]">
    <div class="max-w-2xl">
      <h1 class="font-heading text-[2.5rem] font-medium leading-[1.08] text-background sm:text-[3.25rem] lg:text-[4rem]">
        La claridad que tu contador <em class="italic text-accent">nunca</em> te dio.
      </h1>

      <p class="mt-6 max-w-lg font-body text-[16px] leading-relaxed text-background/70 sm:text-[17px]">
        Declaraciones al día, contabilidad ordenada y remuneraciones sin errores. Con alguien que
        te explica qué está pasando, no solo que lo resuelve por ti.
      </p>

      <div class="mt-9 flex flex-wrap items-center gap-x-8 gap-y-4">
        <a
          href="#contacto"
          class="inline-flex items-center rounded-md bg-accent px-6 py-3 font-body text-[14px] font-medium text-on-accent shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:bg-background hover:shadow-[0_12px_28px_-8px_rgba(245,244,240,0.45)]"
        >
          Conversemos de tu caso
        </a>
        <a
          href="/servicios/"
          class="group inline-flex items-center gap-1.5 font-body text-[14px] font-medium text-background/85 transition-colors hover:text-background"
        >
          <span class="relative">
            Ver los servicios
            <span class="pointer-events-none absolute inset-x-0 -bottom-0.5 h-px bg-background/30" aria-hidden="true"></span>
            <span
              class="pointer-events-none absolute inset-x-0 -bottom-0.5 h-px origin-left scale-x-0 bg-accent transition-transform duration-300 ease-out group-hover:scale-x-100"
              aria-hidden="true"
            ></span>
          </span>
          <svg class="h-3.5 w-3.5" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4M9.5 2.5V8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>
    </div>

    <div class="justify-self-center">
      <HeroConstellation />
    </div>
  </div>
</section>

<style>
  .hero-dark {
    background: radial-gradient(circle at 72% 45%, var(--rt-secondary) 0%, var(--rt-primary) 45%, var(--rt-primary-deep) 100%);
  }
</style>
