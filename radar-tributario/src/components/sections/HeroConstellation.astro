---
// Esfera wireframe + 2 anillos con íconos de documento orbitando + partículas,
// en Three.js. Adaptado del prototipo rt-hero-constelacion.html: mismo rig,
// mismos colores de marca, pero centrado y reescalado para encajar en un
// contenedor cuadrado (el prototipo original asumía un canvas ancho con el
// rig corrido a la derecha).
---

<div class="hero-constellation hidden lg:block" aria-hidden="true">
  <canvas id="hero-constellation-canvas"></canvas>
</div>

<style>
  .hero-constellation {
    position: relative;
    width: 24rem;
    height: 24rem;
  }
  .hero-constellation canvas {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
  }
  @media (min-width: 1280px) {
    .hero-constellation {
      width: 28rem;
      height: 28rem;
    }
  }
</style>

<script>
  import * as THREE from 'three';

  const container = document.querySelector<HTMLDivElement>('.hero-constellation');
  const canvas = document.getElementById('hero-constellation-canvas') as HTMLCanvasElement | null;
  if (!container || !canvas) throw new Error('hero-constellation: missing container/canvas');

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const ACCENT = 0x22e0c4;
  const SECONDARY = 0x3d5a80;
  const DIM = 0x6a86a8;

  let renderer: THREE.WebGLRenderer;
  try {
    renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
  } catch {
    container.style.display = 'none';
    throw new Error('hero-constellation: WebGL unavailable');
  }

  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(38, 1, 0.1, 100);
  camera.position.set(0, 0.3, 12.5);

  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

  const rig = new THREE.Group();
  scene.add(rig);

  const sphereGeo = new THREE.SphereGeometry(1.5, 20, 14);
  const wireGeo = new THREE.WireframeGeometry(sphereGeo);
  const globe = new THREE.LineSegments(wireGeo, new THREE.LineBasicMaterial({ color: ACCENT, transparent: true, opacity: 0.55 }));
  rig.add(globe);

  function makeRing(rx: number, ry: number, color: number, opacity: number, rotX: number, rotY: number, rotZ: number) {
    const curve = new THREE.EllipseCurve(0, 0, rx, ry, 0, Math.PI * 2, false, 0);
    const points = curve.getPoints(96).map((p) => new THREE.Vector3(p.x, p.y, 0));
    const geo = new THREE.BufferGeometry().setFromPoints(points);
    const mat = new THREE.LineBasicMaterial({ color, transparent: true, opacity });
    const line = new THREE.LineLoop(geo, mat);
    line.rotation.set(rotX, rotY, rotZ);
    return line;
  }

  const ringA = makeRing(3.1, 3.1, ACCENT, 0.45, 1.35, 0.25, 0.15);
  const ringB = makeRing(2.6, 2.6, SECONDARY, 0.5, 1.1, -0.4, -0.2);
  rig.add(ringA, ringB);

  function makeFileTexture(kind: 'lines' | 'check', color: string) {
    const s = 64;
    const cnv = document.createElement('canvas');
    cnv.width = s;
    cnv.height = s;
    const ctx = cnv.getContext('2d')!;
    ctx.clearRect(0, 0, s, s);
    ctx.strokeStyle = color;
    ctx.fillStyle = color;
    ctx.lineWidth = 2.5;
    const x = 16,
      y = 8,
      w = 32,
      h = 44,
      fold = 10;
    ctx.beginPath();
    ctx.moveTo(x, y);
    ctx.lineTo(x + w - fold, y);
    ctx.lineTo(x + w, y + fold);
    ctx.lineTo(x + w, y + h);
    ctx.lineTo(x, y + h);
    ctx.closePath();
    ctx.stroke();
    ctx.beginPath();
    ctx.moveTo(x + w - fold, y);
    ctx.lineTo(x + w - fold, y + fold);
    ctx.lineTo(x + w, y + fold);
    ctx.stroke();

    ctx.globalAlpha = 0.85;
    ctx.lineWidth = 2;
    if (kind === 'lines') {
      [0, 1, 2].forEach((i) => {
        ctx.beginPath();
        ctx.moveTo(x + 6, y + 18 + i * 8);
        ctx.lineTo(x + w - 6, y + 18 + i * 8);
        ctx.stroke();
      });
    } else {
      ctx.beginPath();
      ctx.moveTo(x + 8, y + 28);
      ctx.lineTo(x + 15, y + 35);
      ctx.lineTo(x + w - 8, y + 18);
      ctx.stroke();
    }
    const tex = new THREE.CanvasTexture(cnv);
    tex.needsUpdate = true;
    return tex;
  }

  function addOrbitIcons(ring: THREE.LineLoop, params: number[], color: string, kind: 'lines' | 'check', scale: number) {
    params.forEach((t) => {
      const p = (ring.geometry as THREE.BufferGeometry).attributes.position;
      const idx = Math.floor(t * (p.count - 1));
      const sprite = new THREE.Sprite(new THREE.SpriteMaterial({ map: makeFileTexture(kind, color), transparent: true, depthWrite: false }));
      sprite.position.set(p.getX(idx), p.getY(idx), 0);
      sprite.scale.set(scale, scale, 1);
      ring.add(sprite);
    });
  }

  addOrbitIcons(ringA, [0.06, 0.4, 0.72], '#dffaf5', 'lines', 0.55);
  addOrbitIcons(ringB, [0.2, 0.62], '#22e0c4', 'check', 0.46);

  function makeParticles(count: number, radiusMin: number, radiusMax: number, color: number, size: number, opacity: number) {
    const positions = new Float32Array(count * 3);
    for (let i = 0; i < count; i++) {
      const r = radiusMin + Math.random() * (radiusMax - radiusMin);
      const theta = Math.random() * Math.PI * 2;
      const phi = Math.acos(Math.random() * 2 - 1);
      positions[i * 3] = r * Math.sin(phi) * Math.cos(theta);
      positions[i * 3 + 1] = r * Math.sin(phi) * Math.sin(theta) * 0.6;
      positions[i * 3 + 2] = r * Math.cos(phi);
    }
    const geo = new THREE.BufferGeometry();
    geo.setAttribute('position', new THREE.BufferAttribute(positions, 3));
    const mat = new THREE.PointsMaterial({ color, size, sizeAttenuation: true, transparent: true, opacity });
    return new THREE.Points(geo, mat);
  }

  const particlesBright = makeParticles(40, 1.9, 3.6, ACCENT, 0.045, 0.85);
  const particlesDim = makeParticles(55, 2.5, 4.3, DIM, 0.032, 0.5);
  rig.add(particlesBright, particlesDim);

  let mouseX = 0,
    mouseY = 0;
  window.addEventListener('mousemove', (e) => {
    const rect = container.getBoundingClientRect();
    mouseX = ((e.clientX - rect.left) / rect.width) * 2 - 1;
    mouseY = ((e.clientY - rect.top) / rect.height) * 2 - 1;
  });

  let isVisible = true;
  new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        isVisible = entry.isIntersecting;
      });
    },
    { threshold: 0.05 }
  ).observe(container);

  function resize() {
    const w = container.clientWidth,
      h = container.clientHeight;
    if (w === 0 || h === 0) return;
    camera.aspect = w / h;
    camera.updateProjectionMatrix();
    renderer.setSize(w, h);
  }
  window.addEventListener('resize', resize);
  resize();

  if (reduceMotion) {
    globe.rotation.y = 0.6;
    ringA.rotation.z = 0.4;
    renderer.render(scene, camera);
  } else {
    const clock = new THREE.Clock();
    function animate() {
      requestAnimationFrame(animate);
      if (!isVisible) return;
      const t = clock.getElapsedTime();

      globe.rotation.y = t * 0.18;
      ringA.rotation.z = t * 0.12;
      ringB.rotation.z = -t * 0.09;
      rig.rotation.y += (mouseX * 0.25 - rig.rotation.y) * 0.03;
      rig.rotation.x += (-mouseY * 0.12 - rig.rotation.x) * 0.03;

      particlesBright.rotation.y = t * 0.03;
      particlesDim.rotation.y = -t * 0.02;

      renderer.render(scene, camera);
    }
    animate();
  }
</script>
