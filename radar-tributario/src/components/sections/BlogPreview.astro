---
import { getPosts } from '../../lib/sanity/queries';
import PostCard from '../blog/PostCard.astro';

const posts = (await getPosts()).slice(0, 4);
---

<section class="border-t border-primary/10 bg-surface">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
    <div class="flex flex-col gap-6 border-b border-primary/10 pb-8 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-xl">
        <p class="font-body text-[11px] font-semibold uppercase tracking-[0.12em] text-secondary">Noticias</p>
        <h2 class="mt-2 font-heading text-3xl font-medium leading-[1.15] text-primary sm:text-4xl">
          Análisis con fuente citada, no relleno de blog corporativo.
        </h2>
        <p class="mt-4 max-w-md font-body text-[15px] leading-relaxed text-text/75">
          Cada artículo cita la fuente oficial detrás — SII, Banco Central, TGR o Diario Oficial —
          para que sepas de dónde sale la información, no solo qué opinamos nosotros. Estos son los
          últimos 4 publicados, del más reciente al más antiguo.
        </p>
      </div>
      {
        posts.length > 0 && (
          <a
            href="/noticias/"
            class="inline-flex shrink-0 items-center gap-1.5 rounded-md bg-primary px-5 py-2.5 font-body text-[13px] font-medium text-background shadow-sm transition-colors hover:bg-accent hover:text-on-accent"
          >
            Ver todas las noticias
            <svg class="h-3.5 w-3.5" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4M9.5 2.5V8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        )
      }
    </div>

    {
      posts.length === 0 ? (
        <div class="mt-10 flex flex-col justify-center border-l border-dashed border-muted/40 pl-6">
          <p class="font-heading text-2xl italic text-primary">Estamos preparando los primeros análisis.</p>
          <p class="mt-3 max-w-md font-body text-[14.5px] leading-relaxed text-muted">
            Reforma tributaria, resoluciones del SII, IVA y gestión pyme, siempre citando la fuente oficial.
            El primer análisis se publica pronto — mientras tanto, puedes explorar los temas que vamos a cubrir.
          </p>
        </div>
      ) : (
        <div class="mt-10 grid grid-cols-1 items-stretch gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {posts.map((post, i) => <PostCard post={post} badge={i === 0 ? 'Más reciente' : undefined} />)}
        </div>
      )
    }
  </div>
</section>
