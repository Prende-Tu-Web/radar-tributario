---
import { getAllServices } from '../../lib/sanity/queries';
import { PILLAR_ICON_PATHS } from '../../lib/pillar-icons';
import type { Pillar, Service } from '../../lib/sanity/types';

const services = await getAllServices();

const PILLARS: { key: Pillar; label: string; blurb: string }[] = [
  { key: 'tributario', label: 'Tributario', blurb: 'Todo lo que pide el SII, resuelto a tiempo' },
  { key: 'contable', label: 'Contable', blurb: 'Números claros, mes a mes' },
  { key: 'rrhh', label: 'RRHH', blurb: 'Tu equipo, en regla' },
];

const columns = PILLARS.map((p) => ({
  ...p,
  services: services.filter((s: Service) => s.pillar === p.key).slice(0, 2),
}));
---

<section class="bg-surface">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-24">
    <div class="flex flex-col justify-between gap-4 border-b border-primary/10 pb-8 sm:flex-row sm:items-end">
      <h2 class="font-heading text-3xl font-medium text-primary sm:text-4xl">Un servicio para cada etapa</h2>
      <a
        href="/servicios/"
        class="group inline-flex shrink-0 items-center gap-1.5 rounded-md bg-primary px-5 py-2.5 font-body text-[13px] font-medium text-background shadow-sm transition-colors hover:bg-accent hover:text-on-accent"
      >
        Ver el catálogo completo
        <svg class="h-3.5 w-3.5 transition-transform duration-300 group-hover:rotate-45" viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4M9.5 2.5V8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>

    <div class="mt-10 grid grid-cols-1 gap-10 sm:grid-cols-3 sm:gap-8">
      {
        columns.map((col) => (
          <div>
            <div class="flex items-center gap-2.5">
              <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-primary/[0.06] text-primary">
                <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={PILLAR_ICON_PATHS[col.key]} />
              </span>
              <p class="font-body text-[11px] font-semibold uppercase tracking-[0.12em] text-secondary">{col.label}</p>
            </div>
            <p class="mt-2 font-body text-[13px] text-muted">{col.blurb}</p>
            <ul class="mt-5 space-y-4 border-t border-primary/10 pt-5">
              {col.services.map((s: Service) => (
                <li>
                  <a
                    href={`/servicios/${s.pillar}/${s.slug.current}/`}
                    class="group flex items-start justify-between gap-3 font-body text-[15px] leading-snug text-text transition-colors hover:text-secondary"
                  >
                    <span class="relative">
                      {s.title}
                      <span class="pointer-events-none absolute inset-x-0 -bottom-0.5 h-px bg-primary/20" aria-hidden="true" />
                      <span
                        class="pointer-events-none absolute inset-x-0 -bottom-0.5 h-px origin-left scale-x-0 bg-accent transition-transform duration-300 ease-out group-hover:scale-x-100"
                        aria-hidden="true"
                      />
                    </span>
                    <svg
                      class="mt-1 h-3 w-3 shrink-0 text-primary/30 transition-all duration-300 group-hover:rotate-45 group-hover:text-secondary"
                      viewBox="0 0 12 12"
                      fill="none"
                      aria-hidden="true"
                    >
                      <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4M9.5 2.5V8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </a>
                </li>
              ))}
            </ul>
            <a
              href={`/servicios/${col.key}/`}
              class="mt-5 inline-block font-body text-[13px] font-medium text-primary/70 underline decoration-primary/20 underline-offset-4 hover:text-secondary hover:decoration-accent"
            >
              Ver {col.label.toLowerCase()} completo
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>
