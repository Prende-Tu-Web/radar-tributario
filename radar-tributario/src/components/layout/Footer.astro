---
import { getSiteSettings } from '../../lib/sanity/queries';
import { SOCIAL_ICONS } from '../../lib/social-icons';

const siteSettings = await getSiteSettings();
const year = new Date().getFullYear();

const companyLinks = [
  { label: 'Sobre Nosotros', href: '/sobre-nosotros/' },
  { label: 'Noticias', href: '/noticias/' },
  { label: 'Contacto', href: '/contacto/' },
];

// Íconos de sección, mismo criterio thin-stroke del resto del sitio.
const SECTION_ICONS = {
  radar: '<circle cx="12" cy="12" r="1.6" fill="currentColor" stroke="none" /><path d="M12 4a8 8 0 0 1 8 8" /><path d="M12 8a4 4 0 0 1 4 4" />',
  contact: '<rect x="2" y="4" width="20" height="16" rx="2.5" /><path d="M22 6.5l-10 7-10-7" />',
};

// Cuentas reales (2026-07-17). X todavía no existe — apunta a LinkedIn
// mientras tanto, a pedido del cliente; cuando creen la cuenta de X, solo
// hay que cambiar esta URL (o cargar siteSettings.socialLinks en Sanity,
// que tiene prioridad si existe).
const DEFAULT_SOCIALS = [
  { platform: 'linkedin', url: 'https://www.linkedin.com/company/radar-tributario' },
  { platform: 'instagram', url: 'https://www.instagram.com/radartributario.cl' },
  { platform: 'x', url: 'https://www.linkedin.com/company/radar-tributario' },
];

const socials = (siteSettings?.socialLinks && siteSettings.socialLinks.length > 0 ? siteSettings.socialLinks : DEFAULT_SOCIALS).filter((s) =>
  SOCIAL_ICONS[s.platform.toLowerCase()]
);
---

<footer class="relative overflow-hidden bg-primary">
  <!-- Misma foto + bg-fixed que CTASection: al fijar el fondo al viewport (no
       a la sección), la imagen queda perfectamente alineada entre ambas
       secciones — se ve como una sola foto continua, no como dos recortes
       independientes de la misma foto (eso se veía "repetido"). -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
    <div
      class="absolute inset-0 bg-cover bg-center bg-fixed opacity-45"
      style="background-image: url('https://images.unsplash.com/photo-1767988048897-2dca103ff620?fm=jpg&q=60&w=1600&auto=format&fit=crop')"
    >
    </div>
    <div class="absolute inset-0 bg-gradient-to-b from-primary/75 via-primary/85 to-primary/95"></div>
    <span class="absolute -bottom-10 -right-6 select-none font-heading text-[13rem] italic leading-none text-white/[0.03] sm:text-[16rem]">§</span>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8 lg:py-20">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-[1.6fr_1fr_1fr]">
      <div>
        <a href="/" class="font-heading text-xl italic font-semibold text-background">Radar Tributario</a>
        <p class="mt-4 max-w-sm font-body text-[14px] leading-relaxed text-background/60">
          {siteSettings?.tagline ?? 'Asesoría tributaria, contable y de RRHH para independientes, pymes y empresas en Chile.'}
        </p>

        <ul class="mt-6 flex gap-3">
          {
            socials.map((s) => {
              const key = s.platform.toLowerCase();
              const icon = SOCIAL_ICONS[key];
              const iconSvg = icon.filled ? (
                <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor" set:html={icon.path} />
              ) : (
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={icon.path} />
              );
              return (
                <li>
                  <a
                    href={s.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={s.platform}
                    class="flex h-9 w-9 items-center justify-center rounded-full border border-white/15 text-background/70 transition-all hover:-translate-y-0.5 hover:border-accent hover:bg-accent hover:text-on-accent"
                  >
                    {iconSvg}
                  </a>
                </li>
              );
            })
          }
        </ul>
      </div>

      <div>
        <p class="flex items-center gap-2 font-body text-[11px] font-semibold uppercase tracking-[0.12em] text-accent">
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={SECTION_ICONS.radar} />
          Radar Tributario
        </p>
        <ul class="mt-4 space-y-2.5">
          {companyLinks.map((l) => (
            <li>
              <a href={l.href} class="group inline-block font-body text-[13.5px] text-background/70 transition-colors hover:text-background">
                <span class="relative">
                  {l.label}
                  <span class="pointer-events-none absolute inset-x-0 -bottom-0.5 h-px origin-left scale-x-0 bg-accent transition-transform duration-300 ease-out group-hover:scale-x-100" aria-hidden="true" />
                </span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <p class="flex items-center gap-2 font-body text-[11px] font-semibold uppercase tracking-[0.12em] text-accent">
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={SECTION_ICONS.contact} />
          Contacto
        </p>
        <ul class="mt-4 space-y-2.5 font-body text-[13.5px] text-background/70">
          {siteSettings?.contactEmail && (
            <li>
              <a href={`mailto:${siteSettings.contactEmail}`} class="group inline-block transition-colors hover:text-background">
                <span class="relative">
                  {siteSettings.contactEmail}
                  <span class="pointer-events-none absolute inset-x-0 -bottom-0.5 h-px origin-left scale-x-0 bg-accent transition-transform duration-300 ease-out group-hover:scale-x-100" aria-hidden="true" />
                </span>
              </a>
            </li>
          )}
          {siteSettings?.whatsappNumber && (
            <li>
              <a href={`https://wa.me/${siteSettings.whatsappNumber}`} target="_blank" rel="noopener noreferrer" class="group inline-block transition-colors hover:text-background">
                <span class="relative">
                  WhatsApp
                  <span class="pointer-events-none absolute inset-x-0 -bottom-0.5 h-px origin-left scale-x-0 bg-accent transition-transform duration-300 ease-out group-hover:scale-x-100" aria-hidden="true" />
                </span>
              </a>
            </li>
          )}
        </ul>
      </div>
    </div>

    <div class="mt-14 border-t border-white/10 pt-6">
      <p class="font-body text-[12px] leading-relaxed text-background/50">
        {siteSettings?.legalDisclaimer ??
          'La información publicada en este sitio tiene fines informativos y no constituye asesoría tributaria, contable ni legal vinculante. Cada caso debe evaluarse de forma particular.'}
      </p>
      <div class="mt-4 flex flex-wrap items-center gap-x-5 gap-y-2 font-body text-[12px] text-background/60">
        <a href="/politica-de-privacidad/" class="hover:text-background hover:underline">Política de Privacidad</a>
        <a href="/politica-de-cookies/" class="hover:text-background hover:underline">Política de Cookies</a>
        <a href="/terminos-y-condiciones/" class="hover:text-background hover:underline">Términos y Condiciones</a>
        <button type="button" data-cookie-preferences class="cursor-pointer hover:text-background hover:underline">Preferencias de cookies</button>
      </div>
      <p class="mt-4 font-body text-[12px] text-background/50">&copy; {year} Radar Tributario. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>

<script>
  document.querySelectorAll('[data-cookie-preferences]').forEach((el) => {
    el.addEventListener('click', () => {
      window.dispatchEvent(new Event('rt-open-cookie-preferences'));
    });
  });
</script>
