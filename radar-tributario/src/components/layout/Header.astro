---
import type { SiteSettings } from '../../lib/sanity/types';

interface Props {
  siteSettings: SiteSettings | null;
}

const { siteSettings } = Astro.props;

const navLinks = [
  { label: 'Noticias', href: '/noticias/' },
  { label: 'Sobre Nosotros', href: '/sobre-nosotros/' },
  { label: 'Contacto', href: '/contacto/' },
];

// "Agenda una reunión" va directo a Calendly si está configurado; si no,
// cae a /contacto/ en vez de mostrar un botón roto.
const scheduleHref = siteSettings?.calendlyUrl || '/contacto/';
const scheduleIsExternal = Boolean(siteSettings?.calendlyUrl);

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-40 border-b border-white/10 bg-primary">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:h-20 lg:px-8">
    <!-- Logo real (radartributario.cl/logo.png) — diseñado para fondo navy -->
    <a href="/" class="flex shrink-0 items-center">
      <img src="/logo.png" alt="Radar Tributario" class="h-8 w-auto lg:h-9" />
    </a>

    <!-- Desktop nav -->
    <nav aria-label="Principal" class="hidden items-center gap-1 lg:flex">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            aria-current={currentPath === link.href ? 'page' : undefined}
            class:list={[
              'rounded-md px-4 py-2 font-body text-[13px] font-medium uppercase tracking-[0.08em] transition-colors hover:text-accent',
              currentPath === link.href ? 'text-accent' : 'text-background/75',
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <a
        href={scheduleHref}
        target={scheduleIsExternal ? '_blank' : undefined}
        rel={scheduleIsExternal ? 'noopener noreferrer' : undefined}
        class="hidden rounded-md bg-accent px-4 py-2 font-body text-[13px] font-medium text-on-accent shadow-sm transition-opacity hover:opacity-90 sm:inline-flex sm:items-center"
      >
        Agenda una asesoría
      </a>

      <!-- Mobile toggle -->
      <button
        id="mobile-menu-trigger"
        type="button"
        aria-haspopup="true"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Abrir menú"
        class="flex h-11 w-11 cursor-pointer items-center justify-center rounded-md text-background lg:hidden"
      >
        <svg id="icon-open" class="h-6 w-6" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" />
        </svg>
        <svg id="icon-close" class="hidden h-6 w-6" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" hidden class="border-t border-white/10 bg-primary lg:hidden">
    <nav aria-label="Principal (móvil)" class="mx-auto max-w-7xl px-4 py-4 sm:px-6">
      <div class="flex flex-col gap-1 pt-2">
        {navLinks.map((link) => (
          <a href={link.href} class="py-3 font-body text-[13px] font-medium uppercase tracking-[0.08em] text-background/90">{link.label}</a>
        ))}
      </div>
      <a
        href={scheduleHref}
        target={scheduleIsExternal ? '_blank' : undefined}
        rel={scheduleIsExternal ? 'noopener noreferrer' : undefined}
        class="mt-3 block rounded-md bg-accent px-4 py-3 text-center font-body text-[13px] font-medium text-on-accent shadow-sm"
      >
        Agenda una asesoría
      </a>
    </nav>
  </div>
</header>

<script>
  function setExpanded(el: Element, expanded: boolean) {
    el.setAttribute('aria-expanded', String(expanded));
  }

  // Mobile menu
  const mobileTrigger = document.getElementById('mobile-menu-trigger');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  mobileTrigger?.addEventListener('click', () => {
    if (!mobileMenu) return;
    const isOpen = mobileTrigger.getAttribute('aria-expanded') === 'true';
    setExpanded(mobileTrigger, !isOpen);
    mobileMenu.hidden = isOpen;
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
  });
</script>
