---
import type { Service } from '../../lib/sanity/types';

interface Props {
  relatedServices: Service[];
}

const { relatedServices } = Astro.props;
---

<section class="border-t border-primary/10 bg-background">
  <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
    <div class="flex items-end justify-between gap-6">
      <h2 class="font-heading text-2xl font-medium text-primary">Este combo incluye</h2>
      <p class="shrink-0 font-heading text-4xl leading-none text-accent">{relatedServices.length}</p>
    </div>
    <ul class="mt-7 space-y-3">
      {
        relatedServices.map((s) => (
          <li>
            <a
              href={`/servicios/${s.pillar}/${s.slug.current}/`}
              class="group flex items-center justify-between gap-3 rounded-lg border border-primary/10 bg-surface px-5 py-4 font-body text-[14px] text-text shadow-sm transition-all hover:-translate-y-0.5 hover:border-primary/25 hover:text-primary hover:shadow-md"
            >
              {s.title}
              <svg
                class="h-3.5 w-3.5 shrink-0 text-primary/30 transition-all duration-300 group-hover:rotate-45 group-hover:text-secondary"
                viewBox="0 0 12 12"
                fill="none"
                aria-hidden="true"
              >
                <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4M9.5 2.5V8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
