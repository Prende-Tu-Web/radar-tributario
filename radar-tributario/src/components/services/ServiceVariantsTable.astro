---
import type { ServiceVariant } from '../../lib/sanity/types';

interface Props {
  variants: ServiceVariant[];
}

const { variants } = Astro.props;
---

<section class="border-t border-primary/10 bg-background">
  <div class="mx-auto max-w-4xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    <p class="font-body text-[11px] font-semibold uppercase tracking-[0.12em] text-secondary">Según tu caso</p>
    <h2 class="mt-2 font-heading text-2xl font-medium text-primary">Este servicio tiene {variants.length} variantes</h2>

    <div class="mt-7 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        variants.map((v) => (
          <div class="rounded-xl border border-primary/15 bg-surface p-5 shadow-sm transition-all hover:-translate-y-0.5 hover:border-primary/30 hover:shadow-md">
            <h3 class="font-heading text-lg font-medium text-primary">{v.title}</h3>
            {v.idealFor && <p class="mt-1 font-body text-[12.5px] font-medium text-secondary">{v.idealFor}</p>}
            {v.description && <p class="mt-3 font-body text-[13.5px] leading-relaxed text-text/75">{v.description}</p>}
          </div>
        ))
      }
    </div>
    <p class="mt-5 font-body text-[13px] text-muted">
      ¿No sabes cuál te corresponde? Cuéntanos tu caso en el formulario y te lo confirmamos sin costo.
    </p>
  </div>
</section>
