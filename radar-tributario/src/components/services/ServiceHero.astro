---
import type { Service } from '../../lib/sanity/types';
import { getServiceIconPaths } from '../../lib/service-icons';
import { TARGET_AUDIENCE_LABEL } from '../../lib/target-audience';

interface Props {
  service: Service;
  pillarLabel: string;
  hasFaq?: boolean;
}

const { service, pillarLabel, hasFaq = false } = Astro.props;
const iconPaths = getServiceIconPaths(service.slug.current, service.pillar);
---

<section class="relative overflow-hidden bg-surface">
  <span
    aria-hidden="true"
    class="pointer-events-none absolute -right-10 -top-16 text-primary/[0.035]"
  >
    <svg class="h-[22rem] w-[22rem] sm:h-[28rem] sm:w-[28rem]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.7" stroke-linecap="round" stroke-linejoin="round" set:html={iconPaths} />
  </span>

  <div class="relative mx-auto max-w-4xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
    <div class="flex items-center gap-4">
      <span class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-primary/[0.06] text-primary">
        <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={iconPaths} />
      </span>
      <p class="font-body text-[11px] font-semibold uppercase tracking-[0.12em] text-secondary">{pillarLabel}</p>
    </div>

    <h1 class="mt-5 font-heading text-[2rem] font-medium leading-[1.12] text-primary sm:text-[2.5rem]">
      {service.title}
    </h1>
    {
      service.heroDescription && (
        <p class="mt-5 max-w-2xl font-body text-[16px] leading-relaxed text-text/80">{service.heroDescription}</p>
      )
    }

    {
      service.targetAudience && service.targetAudience.length > 0 && (
        <ul class="mt-6 flex flex-wrap gap-2">
          {service.targetAudience.map((a) => (
            <li class="rounded-full border border-primary/15 bg-background px-3 py-1.5 font-body text-[12px] font-medium text-text/80">
              {TARGET_AUDIENCE_LABEL[a]}
            </li>
          ))}
        </ul>
      )
    }

    <div class="mt-8 flex flex-wrap items-center gap-x-8 gap-y-4">
      <a
        href="#contacto-servicio"
        class="inline-flex items-center rounded-md bg-primary px-6 py-3 font-body text-[14px] font-medium text-background shadow-sm transition-colors hover:bg-accent hover:text-on-accent"
      >
        Cotiza este servicio
      </a>
      {
        hasFaq && (
          <a href="#faq-servicio" class="group inline-flex items-center gap-1.5 font-body text-[14px] font-medium text-primary transition-colors hover:text-secondary">
            <span class="relative">
              Ver preguntas frecuentes
              <span class="pointer-events-none absolute inset-x-0 -bottom-0.5 h-px bg-primary/30" aria-hidden="true" />
              <span
                class="pointer-events-none absolute inset-x-0 -bottom-0.5 h-px origin-left scale-x-0 bg-accent transition-transform duration-300 ease-out group-hover:scale-x-100"
                aria-hidden="true"
              />
            </span>
          </a>
        )
      }
    </div>
  </div>
</section>
