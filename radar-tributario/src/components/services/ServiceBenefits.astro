---
import type { ServiceBenefit } from '../../lib/sanity/types';

interface Props {
  benefits: ServiceBenefit[];
}

const { benefits } = Astro.props;
---

<section class="bg-surface">
  <div class="mx-auto max-w-4xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    <h2 class="font-heading text-2xl font-medium text-primary">Qué incluye</h2>
    <ul class="mt-7 grid grid-cols-1 gap-6 border-t border-primary/10 pt-7 sm:grid-cols-2">
      {
        benefits.map((b) => (
          <li class="flex gap-4">
            <span class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-accent/15 text-secondary">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20 6L9 17l-5-5" />
              </svg>
            </span>
            <div>
              <h3 class="font-heading text-lg font-medium text-primary">{b.title}</h3>
              {b.description && <p class="mt-1.5 font-body text-[14px] leading-relaxed text-text/75">{b.description}</p>}
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>
