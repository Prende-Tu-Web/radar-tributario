---
import FAQAccordion from '../islands/FAQAccordion';
import type { FaqItem } from '../../lib/sanity/types';

interface Props {
  faq: FaqItem[];
}

const { faq } = Astro.props;
---

<section id="faq-servicio" class="scroll-mt-16 border-t border-primary/10 bg-background lg:scroll-mt-20">
  <div class="mx-auto max-w-3xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    <h2 class="font-heading text-2xl font-medium text-primary">Preguntas frecuentes</h2>
    <div class="mt-6">
      <FAQAccordion client:visible items={faq} />
    </div>
  </div>
</section>
