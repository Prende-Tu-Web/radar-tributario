---
import Ticker from './Ticker.astro';

const nav = [
  { label: 'Inicio', href: '/' },
  { label: 'Noticias', href: '/noticias/' },
  { label: 'Categorías', href: '#', children: [
    { label: 'SII · Resoluciones', href: '/categoria/sii-resoluciones/' },
    { label: 'Impuesto a la Renta', href: '/categoria/impuesto-renta/' },
    { label: 'IVA', href: '/categoria/iva/' },
    { label: 'Pymes', href: '/categoria/pymes/' },
    { label: 'Reforma Tributaria', href: '/categoria/reforma-tributaria/' },
    { label: 'Fiscalización', href: '/categoria/fiscalizacion/' },
    { label: 'Internacional', href: '/categoria/internacional/' },
    { label: 'Contabilidad', href: '/categoria/contabilidad/' },
    { label: 'Laboral Tributario', href: '/categoria/laboral-tributario/' },
  ]},
  { label: 'Nosotros', href: '/sobre-nosotros/' },
  { label: 'Contacto', href: '/contacto/' },
];

const pathname = Astro.url.pathname;
---

<Ticker />

<header class="bg-white border-b border-rt-border sticky top-0 z-50 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 flex items-center justify-between h-16">
    <a href="/" class="flex items-center gap-3">
      <img src="/logo.png" alt="Radar Tributario" class="h-9 w-auto" />
    </a>

    <nav class="hidden lg:flex items-center gap-1">
      {nav.map((item) => (
        item.children ? (
          <div class="relative group">
            <button class="px-3 py-2 text-sm font-medium text-rt-text hover:text-rt-navy transition-colors flex items-center gap-1" style="font-family:'Montserrat',sans-serif">
              {item.label}
              <svg class="w-3 h-3 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="absolute top-full left-0 bg-white border border-rt-border shadow-lg rounded-sm min-w-[220px] hidden group-hover:block">
              {item.children.map((child) => (
                <a href={child.href} class="block px-4 py-2.5 text-sm text-rt-text hover:bg-rt-bg hover:text-rt-navy transition-colors border-b border-rt-border last:border-0" style="font-family:'Montserrat',sans-serif">
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={item.href}
            class:list={[
              'px-3 py-2 text-sm font-medium transition-colors',
              pathname === item.href ? 'text-rt-navy font-semibold' : 'text-rt-text hover:text-rt-navy'
            ]}
            style="font-family:'Montserrat',sans-serif"
          >
            {item.label}
          </a>
        )
      ))}
    </nav>

    <!-- Mobile menu button -->
    <button id="mobile-menu-btn" class="lg:hidden p-2 text-rt-navy" aria-label="Abrir menú">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile nav -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-rt-border bg-white">
    <nav class="px-4 py-3 space-y-1">
      {nav.filter(i => !i.children).map((item) => (
        <a href={item.href} class="block py-2 text-sm font-medium text-rt-text hover:text-rt-navy" style="font-family:'Montserrat',sans-serif">
          {item.label}
        </a>
      ))}
      <div class="pt-2 border-t border-rt-border">
        <p class="text-xs text-rt-muted pb-2 font-semibold uppercase tracking-wider" style="font-family:'Montserrat',sans-serif">Categorías</p>
        {nav.find(i => i.children)?.children?.map((child) => (
          <a href={child.href} class="block py-2 text-sm text-rt-text hover:text-rt-navy" style="font-family:'Montserrat',sans-serif">
            {child.label}
          </a>
        ))}
      </div>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
