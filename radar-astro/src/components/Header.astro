---
import Ticker from './Ticker.astro';

const nav = [
  { label: 'Inicio', href: '/' },
  { label: 'Noticias', href: '/noticias/' },
  { label: 'Categorías', href: '#', children: [
    { label: 'SII · Resoluciones', href: '/categoria/sii-resoluciones/' },
    { label: 'Impuesto a la Renta', href: '/categoria/impuesto-renta/' },
    { label: 'IVA', href: '/categoria/iva/' },
    { label: 'Pymes', href: '/categoria/pymes/' },
    { label: 'Reforma Tributaria', href: '/categoria/reforma-tributaria/' },
    { label: 'Fiscalización', href: '/categoria/fiscalizacion/' },
    { label: 'Internacional', href: '/categoria/internacional/' },
    { label: 'Contabilidad', href: '/categoria/contabilidad/' },
    { label: 'Laboral Tributario', href: '/categoria/laboral-tributario/' },
  ]},
  { label: 'Nosotros', href: '/sobre-nosotros/' },
  { label: 'Contacto', href: '/contacto/' },
];

const pathname = Astro.url.pathname;
---

<div class="sticky top-0 z-50">
<Ticker />

<header style="background:#0f2547; border-bottom:1px solid rgba(255,255,255,0.1);">
  <div class="max-w-7xl mx-auto px-4 flex items-center justify-between h-16">
    <a href="/" class="flex items-center gap-3">
      <img src="/logo.png" alt="Radar Tributario" class="h-9 w-auto" />
    </a>

    <nav class="hidden lg:flex items-center gap-1">
      {nav.map((item) => (
        item.children ? (
          <div class="relative group">
            <button
              class="px-3 py-2 text-sm font-medium flex items-center gap-1 transition-colors"
              style="font-family:'Montserrat',sans-serif; color:rgba(255,255,255,0.75);"
            >
              {item.label}
              <svg class="w-3 h-3 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="absolute top-full left-0 shadow-xl min-w-[220px] hidden group-hover:block" style="background:#0f2547; border:1px solid rgba(255,255,255,0.1);">
              {item.children.map((child) => (
                <a
                  href={child.href}
                  class="block px-4 py-2.5 text-sm transition-colors"
                  style="font-family:'Montserrat',sans-serif; color:rgba(255,255,255,0.7); border-bottom:1px solid rgba(255,255,255,0.07);"
                  onmouseover="this.style.color='#22E0C4'"
                  onmouseout="this.style.color='rgba(255,255,255,0.7)'"
                >
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={item.href}
            class="px-3 py-2 text-sm font-medium transition-colors"
            style={`font-family:'Montserrat',sans-serif; color:${pathname === item.href ? '#22E0C4' : 'rgba(255,255,255,0.85)'};`}
          >
            {item.label}
          </a>
        )
      ))}
    </nav>

    <div class="hidden lg:flex items-center gap-3">
      <a
        href="/contacto/#newsletter"
        class="text-xs font-bold px-4 py-2 transition-all"
        style="font-family:'Montserrat',sans-serif; letter-spacing:.06em; background:#c0392b; color:white;"
      >
        Alertas gratis
      </a>
    </div>

    <button id="mobile-menu-btn" class="lg:hidden p-2" style="color:white;" aria-label="Abrir menú">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile nav -->
  <div id="mobile-menu" class="hidden lg:hidden" style="background:#0f2547; border-top:1px solid rgba(255,255,255,0.1);">
    <nav class="px-4 py-3 space-y-1">
      {nav.filter(i => !i.children).map((item) => (
        <a
          href={item.href}
          class="block py-2.5 text-sm font-medium"
          style="font-family:'Montserrat',sans-serif; color:rgba(255,255,255,0.85);"
        >
          {item.label}
        </a>
      ))}
      <div class="pt-3 border-t" style="border-color:rgba(255,255,255,0.1);">
        <p class="text-xs font-bold uppercase tracking-widest pb-2" style="font-family:'Montserrat',sans-serif; color:rgba(255,255,255,0.4);">Categorías</p>
        {nav.find(i => i.children)?.children?.map((child) => (
          <a
            href={child.href}
            class="block py-2 text-sm"
            style="font-family:'Montserrat',sans-serif; color:rgba(255,255,255,0.7);"
          >
            {child.label}
          </a>
        ))}
      </div>
    </nav>
  </div>
</header>
</div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
