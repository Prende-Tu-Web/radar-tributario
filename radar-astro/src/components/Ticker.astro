---
interface Indicator { label: string; value: string; sub?: string }

const fallback: Indicator[] = [
  { label: 'UF',     value: '—' },
  { label: 'UTM',    value: '—' },
  { label: 'Dólar',  value: '—' },
  { label: 'Euro',   value: '—' },
  { label: 'IPC',    value: '—' },
]

function clp(n: number) {
  return '$' + n.toLocaleString('es-CL', { minimumFractionDigits: 0, maximumFractionDigits: 2 })
}

let indicators: Indicator[] = fallback
try {
  const res = await fetch('https://mindicador.cl/api', { signal: AbortSignal.timeout(4000) })
  if (res.ok) {
    const data = await res.json()
    indicators = [
      { label: 'UF',    value: clp(data.uf?.valor),    sub: 'hoy' },
      { label: 'UTM',   value: clp(data.utm?.valor),   sub: new Date(data.utm?.fecha).toLocaleDateString('es-CL', { month: 'short', year: 'numeric' }) },
      { label: 'Dólar', value: clp(data.dolar?.valor),  sub: 'hoy' },
      { label: 'Euro',  value: clp(data.euro?.valor),   sub: 'hoy' },
      { label: 'IPC',   value: data.ipc?.valor + '%',   sub: new Date(data.ipc?.fecha).toLocaleDateString('es-CL', { month: 'short', year: 'numeric' }) },
    ]
  }
} catch {
  // Mantiene fallback si la API no responde
}

const doubled = [...indicators, ...indicators]
---

<div style="background:#0f2547; color:white; overflow:hidden;">
  <div class="flex items-stretch">
    <div class="shrink-0 flex items-center px-4 text-[11px] font-semibold uppercase tracking-wider" style="background:#c0392b; font-family:'Montserrat',sans-serif;">
      Indicadores
    </div>
    <div class="overflow-hidden flex-1">
      <div class="economic-slider py-2">
        {doubled.map((ind) => (
          <span class="inline-flex items-center gap-1.5 px-6 text-[12px]" style="font-family:'Montserrat',sans-serif;">
            <span style="color:#22E0C4;" class="font-semibold">{ind.label}</span>
            <span class="font-medium">{ind.value}</span>
            {ind.sub && <span class="text-gray-500 text-[10px]">{ind.sub}</span>}
            <span class="text-gray-700 mx-2">|</span>
          </span>
        ))}
      </div>
    </div>
  </div>
</div>
