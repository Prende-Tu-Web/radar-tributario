---
// Indicadores económicos — valores se actualizarán vía API en Fase 4
// Por ahora son placeholders estáticos para no bloquear el deploy inicial
const indicators = [
  { label: 'UF', value: '$38.432,16', change: '+0.02%', up: true },
  { label: 'UTM', value: '$67.294', change: '—', up: null },
  { label: 'Dólar', value: '$937,50', change: '-1.20%', up: false },
  { label: 'Euro', value: '$1.012,30', change: '+0.45%', up: true },
  { label: 'IPC', value: '0.3%', change: 'may 2026', up: null },
];
---

<div class="bg-rt-navy text-white overflow-hidden">
  <div class="flex items-stretch">
    <div class="bg-rt-red px-4 flex items-center shrink-0 text-[11px] font-semibold uppercase tracking-wider" style="font-family:'Montserrat',sans-serif">
      Indicadores
    </div>
    <div class="overflow-hidden flex-1 relative">
      <div class="economic-slider py-2">
        {[...indicators, ...indicators].map((ind) => (
          <span class="inline-flex items-center gap-2 px-6 text-[12px]" style="font-family:'Montserrat',sans-serif">
            <span class="text-rt-teal font-semibold">{ind.label}</span>
            <span class="font-medium">{ind.value}</span>
            {ind.change !== '—' && (
              <span class={ind.up === true ? 'text-green-400' : ind.up === false ? 'text-rt-red' : 'text-gray-400'}>
                {ind.change}
              </span>
            )}
            <span class="text-gray-600 mx-2">|</span>
          </span>
        ))}
      </div>
    </div>
  </div>
</div>
