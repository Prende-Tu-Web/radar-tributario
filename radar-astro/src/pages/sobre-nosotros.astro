---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import { sanityClient } from '../lib/sanity';
import type { Author } from '../lib/types';

const authors = await sanityClient.fetch<Author[]>(
  `*[_type == "author"] | order(name asc) { _id, name, slug, bio, credentials }`
);

function authorSlug(name: string) {
  return authors.find(a => a.name.toLowerCase().includes(name.toLowerCase()))?.slug.current ?? '#';
}
---

<BaseLayout
  title="Sobre Nosotros | Radar Tributario"
  description="Conoce al equipo de Radar Tributario: especialistas tributarios comprometidos con la información tributaria en Chile."
>
  <!-- MISIÓN + VALORES -->
  <section class="py-14 bg-white border-b" style="border-color:var(--rt-border);">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">

      <div class="sec-rule">
        <span class="dept" style="color:var(--rt-navy);">Nuestra misión</span>
      </div>

      <div class="grid lg:grid-cols-2 gap-12 items-start">
        <div>
          <h1 class="font-bold leading-tight mb-5" style="font-family:'Rubik',sans-serif; font-size:clamp(1.6rem,3vw,2.4rem); color:var(--rt-navy);">
            Democratizar el conocimiento tributario en Chile
          </h1>
          <p class="text-gray-600 leading-relaxed mb-4" style="font-size:.95rem;">
            En Radar Tributario creemos que la información tributaria debe ser <strong class="text-gray-800">accesible, clara y práctica</strong>. Nuestra misión es proporcionar análisis rigurosos y actualizados que ayuden a empresas y profesionales a navegar el complejo mundo de los impuestos.
          </p>
          <p class="text-gray-600 leading-relaxed" style="font-size:.95rem;">
            Nos esforzamos por traducir la jerga legal en información comprensible, explicando no solo <em>"qué dice la norma"</em>, sino también <em>"por qué importa"</em> y <em>"qué hacer ahora"</em>.
          </p>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="valor-tile">
            <div class="dept mb-2" style="color:var(--rt-teal);">Transparencia</div>
            <p class="text-sm text-gray-500 leading-relaxed">Información clara, sin sesgos, basada en fuentes oficiales del SII y el Congreso.</p>
          </div>
          <div class="valor-tile red">
            <div class="dept mb-2" style="color:var(--rt-red);">Actualidad</div>
            <p class="text-sm text-gray-500 leading-relaxed">Contenido siempre actualizado con los últimos cambios normativos y resoluciones.</p>
          </div>
          <div class="valor-tile navy">
            <div class="dept mb-2" style="color:var(--rt-navy);">Educación</div>
            <p class="text-sm text-gray-500 leading-relaxed">Enfoque educativo que empodera a lectores con herramientas para decidir mejor.</p>
          </div>
          <div class="valor-tile warn">
            <div class="dept mb-2" style="color:var(--rt-warn);">Comunidad</div>
            <p class="text-sm text-gray-500 leading-relaxed">Construimos una comunidad de profesionales tributarios bien informados en Chile.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STAT BAR -->
  <div style="background:var(--rt-navy);">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4">
        <div class="stat-tile">
          <div class="font-bold text-3xl lg:text-4xl mb-1" style="font-family:'Rubik',sans-serif; color:var(--rt-teal);">50+</div>
          <div class="dept text-gray-400">Artículos publicados</div>
        </div>
        <div class="stat-tile">
          <div class="font-bold text-3xl lg:text-4xl mb-1" style="font-family:'Rubik',sans-serif; color:var(--rt-teal);">3.200+</div>
          <div class="dept text-gray-400">Lectores mensuales</div>
        </div>
        <div class="stat-tile">
          <div class="font-bold text-3xl lg:text-4xl mb-1" style="font-family:'Rubik',sans-serif; color:var(--rt-teal);">8+</div>
          <div class="dept text-gray-400">Años de experiencia</div>
        </div>
        <div class="stat-tile">
          <div class="font-bold text-3xl lg:text-4xl mb-1" style="font-family:'Rubik',sans-serif; color:var(--rt-teal);">95%</div>
          <div class="dept text-gray-400">Satisfacción lectores</div>
        </div>
      </div>
    </div>
  </div>

  <!-- EQUIPO -->
  <section class="py-14" style="background:var(--rt-bg);">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="sec-rule">
        <span class="dept" style="color:var(--rt-navy);">Nuestro equipo</span>
        <span class="dept text-gray-400">Contadores · Auditores · Tecnología</span>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <div class="team-card">
          <div class="team-avatar-icon">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:var(--rt-navy);"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </div>
          <div>
            <h3 class="font-bold text-base mb-0.5" style="font-family:'Rubik',sans-serif; color:var(--rt-navy);">
              <a href={`/autor/${authorSlug('Nayadeth')}/`} class="hover:text-rt-teal transition-colors">Nayadeth Miranda</a>
            </h3>
            <div class="dept mb-2" style="color:var(--rt-teal); font-size:.55rem;">Gerenta de Impuestos · CPA</div>
            <p class="text-sm text-gray-500 leading-relaxed">
              Especialista en tributación empresarial. Magíster en gestión tributaria con más de 8 años de experiencia en empresa y consultoría.
            </p>
          </div>
        </div>

        <div class="team-card">
          <div class="team-avatar-icon">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:var(--rt-navy);"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </div>
          <div>
            <h3 class="font-bold text-base mb-0.5" style="font-family:'Rubik',sans-serif; color:var(--rt-navy);">
              <a href={`/autor/${authorSlug('Alexis')}/`} class="hover:text-rt-teal transition-colors">Alexis Contreras</a>
            </h3>
            <div class="dept mb-2" style="color:var(--rt-teal); font-size:.55rem;">Technical Lead · Co-Founder</div>
            <p class="text-sm text-gray-500 leading-relaxed">
              Especialista en análisis tecnológico e implementación de soluciones digitales. Lidera la transformación de Radar Tributario al stack moderno.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA COLABORACIÓN -->
  <section class="py-14 bg-white border-t" style="border-color:var(--rt-border);">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="sec-rule">
            <span class="dept" style="color:var(--rt-navy);">Colabora con nosotros</span>
          </div>
          <h2 class="font-bold leading-tight mb-4" style="font-family:'Rubik',sans-serif; font-size:1.8rem; color:var(--rt-navy);">
            ¿Eres experto en tributación?
          </h2>
          <p class="text-gray-600 leading-relaxed mb-6" style="font-size:.95rem;">
            Si eres contador, abogado tributarista o especialista en normativa fiscal y quieres compartir tu conocimiento con nuestra comunidad, contáctanos. Valoramos la experiencia real y la capacidad de explicar conceptos complejos con claridad.
          </p>
          <div class="flex flex-col sm:flex-row gap-3">
            <a href="/contacto/" class="inline-flex items-center justify-center font-semibold text-sm px-6 py-3 transition-all"
               style="background:var(--rt-navy); color:white; font-family:'Montserrat',sans-serif; letter-spacing:.06em;">
              Contactar →
            </a>
            <a href="/noticias/" class="inline-flex items-center justify-center font-semibold text-sm px-6 py-3 border transition-all"
               style="border-color:var(--rt-navy); color:var(--rt-navy); font-family:'Montserrat',sans-serif;">
              Ver noticias
            </a>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-5 text-center" style="background:var(--rt-bg); border:1px solid var(--rt-border);">
            <div class="font-bold text-2xl mb-1" style="font-family:'Rubik',sans-serif; color:var(--rt-teal);">+500</div>
            <div class="dept text-gray-500 text-xs">Resoluciones SII cubiertas</div>
          </div>
          <div class="p-5 text-center" style="background:var(--rt-bg); border:1px solid var(--rt-border);">
            <div class="font-bold text-2xl mb-1" style="font-family:'Rubik',sans-serif; color:var(--rt-teal);">100%</div>
            <div class="dept text-gray-500 text-xs">Fuentes oficiales</div>
          </div>
          <div class="p-5 text-center" style="background:var(--rt-bg); border:1px solid var(--rt-border);">
            <div class="font-bold text-2xl mb-1" style="font-family:'Rubik',sans-serif; color:var(--rt-teal);">24h</div>
            <div class="dept text-gray-500 text-xs">Respuesta a consultas</div>
          </div>
          <div class="p-5 text-center" style="background:var(--rt-bg); border:1px solid var(--rt-border);">
            <div class="font-bold text-2xl mb-1" style="font-family:'Rubik',sans-serif; color:var(--rt-teal);">Gratis</div>
            <div class="dept text-gray-500 text-xs">Todo el contenido</div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
