---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Sobre Nosotros | Radar Tributario"
  description="Conoce al equipo detrás de Radar Tributario, el referente en análisis tributario para Chile."
>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <div class="sec-rule">Sobre nosotros</div>
    <h1 class="text-3xl font-bold text-rt-navy mb-6" style="font-family:'Rubik',sans-serif">
      El referente tributario que Chile necesitaba
    </h1>
    <p class="text-rt-muted mb-4">
      Contenido en construcción — próximamente disponible.
    </p>
  </div>
</BaseLayout>
