---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contacto | Radar Tributario"
  description="Contáctanos. ¿Preguntas sobre tributación? ¿Quieres colaborar? Estamos aquí para ayudarte."
>
  <div class="bg-white border-b py-3" style="border-color:var(--rt-border);">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-xs" style="font-family:'Montserrat',sans-serif; color:var(--rt-muted);">
        <a href="/" class="hover:text-rt-teal transition-colors">Inicio</a>
        <span>/</span>
        <span style="color:var(--rt-text);">Contacto</span>
      </nav>
    </div>
  </div>

  <section class="py-12 bg-white border-b" style="border-color:var(--rt-border);">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="sec-rule">
        <span class="dept" style="color:var(--rt-navy);">Contacto</span>
      </div>
      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <h1 class="font-bold leading-tight mb-2" style="font-family:'Rubik',sans-serif; font-size:1.7rem; color:var(--rt-navy);">Envíanos un mensaje</h1>
          <p class="text-gray-500 text-sm mb-6">Responderemos en menos de 24 horas hábiles.</p>
          <form id="contact-form" class="space-y-4" novalidate>
            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label for="nombre" class="rt-label">Nombre *</label>
                <input type="text" id="nombre" name="nombre" required class="rt-input" placeholder="Tu nombre completo" />
              </div>
              <div>
                <label for="email" class="rt-label">Email *</label>
                <input type="email" id="email" name="email" required class="rt-input" placeholder="tu@empresa.cl" />
              </div>
            </div>
            <div>
              <label for="empresa" class="rt-label">Empresa</label>
              <input type="text" id="empresa" name="empresa" class="rt-input" placeholder="Nombre de tu empresa (opcional)" />
            </div>
            <div>
              <label for="asunto" class="rt-label">Asunto *</label>
              <select id="asunto" name="asunto" required class="rt-input">
                <option value="">Selecciona un asunto</option>
                <option value="consulta-tributaria">Consulta tributaria general</option>
                <option value="colaboracion">Colaboración editorial</option>
                <option value="sugerencia">Sugerencia de tema</option>
                <option value="reporte-error">Reporte de error</option>
                <option value="otro">Otro</option>
              </select>
            </div>
            <div>
              <label for="mensaje" class="rt-label">Mensaje *</label>
              <textarea id="mensaje" name="mensaje" rows="5" required class="rt-input resize-none" placeholder="Cuéntanos en qué podemos ayudarte…"></textarea>
            </div>
            <div class="flex items-start gap-3">
              <input type="checkbox" id="privacidad" name="privacidad" required class="mt-0.5 w-4 h-4" />
              <label for="privacidad" class="text-xs text-gray-500">
                Acepto la <a href="/politica-privacidad/" style="color:var(--rt-teal);" class="hover:underline">Política de Privacidad</a> y autorizo el tratamiento de mis datos personales.
              </label>
            </div>
            <button type="submit" class="w-full font-semibold py-3.5 text-sm text-white transition-all"
                    style="background:var(--rt-navy); font-family:'Montserrat',sans-serif; letter-spacing:.06em; border-radius:2px;">
              Enviar mensaje →
            </button>
            <div id="form-success" class="hidden py-3 px-4 text-sm text-center" style="background:rgba(34,224,196,.1); border:1px solid var(--rt-teal); color:var(--rt-navy); border-radius:2px;">
              ¡Mensaje enviado! Te responderemos en menos de 24 horas.
            </div>
            <div id="form-error" class="hidden py-3 px-4 text-sm text-center" style="background:rgba(192,57,43,.06); border:1px solid var(--rt-red); color:var(--rt-red); border-radius:2px;">
              Por favor completa todos los campos obligatorios.
            </div>
          </form>
        </div>

        <div>
          <h2 class="font-bold mb-6" style="font-family:'Rubik',sans-serif; font-size:1.25rem; color:var(--rt-navy);">Información de contacto</h2>
          <div class="space-y-6 mb-8">
            <div class="flex items-start gap-4">
              <div style="width:40px;height:40px;border-radius:2px;display:flex;align-items:center;justify-content:center;flex-shrink:0;background:rgba(15,37,71,.08);">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:var(--rt-navy);"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <div>
                <div class="dept mb-1" style="color:var(--rt-navy);">Email</div>
                <a href="mailto:info@radartributario.cl" class="text-sm text-gray-600 hover:text-rt-teal transition-colors">info@radartributario.cl</a>
                <p class="text-xs text-gray-400 mt-0.5">Respondemos en menos de 24 horas hábiles</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div style="width:40px;height:40px;border-radius:2px;display:flex;align-items:center;justify-content:center;flex-shrink:0;background:rgba(15,37,71,.08);">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:var(--rt-navy);"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <div>
                <div class="dept mb-1" style="color:var(--rt-navy);">Horarios de atención</div>
                <p class="text-sm text-gray-600">Lunes a Viernes: 9:00 — 18:00</p>
                <p class="text-xs text-gray-400 mt-0.5">Sábados: 9:00 — 13:00</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div style="width:40px;height:40px;border-radius:2px;display:flex;align-items:center;justify-content:center;flex-shrink:0;background:rgba(15,37,71,.08);">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:var(--rt-navy);"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              <div>
                <div class="dept mb-1" style="color:var(--rt-navy);">Ubicación</div>
                <p class="text-sm text-gray-600">Santiago, Chile</p>
                <p class="text-xs text-gray-400 mt-0.5">Atención principalmente online</p>
              </div>
            </div>
          </div>
          <div class="pt-6 border-t" style="border-color:var(--rt-border);">
            <div class="dept mb-4" style="color:var(--rt-navy);">Síguenos</div>
            <div class="flex gap-3">
              <a href="#" class="w-10 h-10 flex items-center justify-center border hover:border-rt-teal hover:text-rt-teal transition-colors" style="border-color:var(--rt-border);">
                <svg class="w-4 h-4 text-gray-400" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
              <a href="#" class="w-10 h-10 flex items-center justify-center border hover:border-rt-teal hover:text-rt-teal transition-colors" style="border-color:var(--rt-border);">
                <svg class="w-4 h-4 text-gray-400" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12" style="background:var(--rt-bg);">
    <div class="max-w-4xl mx-auto px-6 lg:px-8">
      <div class="sec-rule">
        <span class="dept" style="color:var(--rt-navy);">Preguntas frecuentes</span>
      </div>
      <div>
        {[
          { q: '¿Ofrecen asesoría tributaria personalizada?', a: 'Nos enfocamos en información general y educativa. Para asesoría personalizada, recomendamos consultar con un contador auditor o abogado tributarista habilitado.' },
          { q: '¿Con qué frecuencia actualizan el contenido?', a: 'Publicamos nuevo contenido semanalmente. Cuando hay cambios importantes en la legislación o nuevas circulares del SII, publicamos actualizaciones urgentes.' },
          { q: '¿Puedo colaborar escribiendo artículos?', a: '¡Por supuesto! Buscamos colaboraciones de expertos en tributación. Contáctanos seleccionando "Colaboración editorial" en el formulario.' },
          { q: '¿La información es gratuita?', a: 'Sí, todo nuestro contenido es completamente gratuito. Creemos en democratizar el acceso a la información tributaria.' },
          { q: '¿Cómo puedo sugerir temas para artículos?', a: 'Usa el formulario seleccionando "Sugerencia de tema" o escríbenos a info@radartributario.cl.' },
        ].map(({ q, a }) => (
          <div class="faq-item">
            <div class="faq-question">
              <h3 class="font-semibold text-base" style="font-family:'Rubik',sans-serif; color:var(--rt-text);">{q}</h3>
              <svg class="faq-icon w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </div>
            <div class="faq-answer">
              <p class="text-sm text-gray-500 leading-relaxed pb-2">{a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const nombre     = (document.getElementById('nombre') as HTMLInputElement).value.trim();
    const email      = (document.getElementById('email') as HTMLInputElement).value.trim();
    const asunto     = (document.getElementById('asunto') as HTMLSelectElement).value;
    const mensaje    = (document.getElementById('mensaje') as HTMLTextAreaElement).value.trim();
    const privacidad = (document.getElementById('privacidad') as HTMLInputElement).checked;
    const success    = document.getElementById('form-success')!;
    const error      = document.getElementById('form-error')!;
    success.classList.add('hidden');
    error.classList.add('hidden');
    if (!nombre || !email || !asunto || !mensaje || !privacidad) {
      error.classList.remove('hidden');
      return;
    }
    success.classList.remove('hidden');
    (e.target as HTMLFormElement).reset();
  });

  document.querySelectorAll('.faq-question').forEach(q => {
    q.addEventListener('click', () => {
      q.nextElementSibling?.classList.toggle('open');
      q.querySelector('.faq-icon')?.classList.toggle('rotated');
    });
  });
</script>
