---
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  noIndex?: boolean;
  ogImage?: string;
}

const { title, description, canonical, noIndex, ogImage } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <SEOHead
    title={title}
    description={description}
    canonical={canonical}
    noIndex={noIndex}
    ogImage={ogImage}
  />
</head>
<body class="min-h-screen flex flex-col">
  <Header />
  <main class="flex-1">
    <slot />
  </main>
  <Footer />
</body>
</html>
